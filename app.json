{
  "expo": {
    "name": "PantryPal",
    "slug": "pantrypal-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F5F1"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-web-browser"],
    "extra": {
      "eas": {
        "projectId": "45aae26e-171d-4af3-87f8-e407ec037262"
      }
    },
    "owner": "sherminh"
  }
}
